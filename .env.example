# Password to the new Supabase DB you create
SUPABASE_DB_PASSWORD=

# Transaction pooler connection URI from Supabase (used by the agent to query the database)
SUPABASE_URL=

# Session pooler connection URI from Supabase (used by LangGraph Server for persistence)
DATABASE_URI=

# OpenAI API key (required)
OPENAI_API_KEY=

# Optional: LangSmith for tracing and observability
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=delishes-chatbot

# Optional: Redis URI (for deployment on Render)
REDIS_URI=

# Optional: LangGraph Server URL (once deployed)
LANGGRAPH_SERVER_URL=
